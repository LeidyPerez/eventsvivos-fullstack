{
  "openapi": "3.0.4",
  "info": {
    "title": "EventosVivos.API",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Eventos": {
      "post": {
        "tags": [
          "Eventos"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CrearEventoDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CrearEventoDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CrearEventoDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Eventos"
        ],
        "parameters": [
          {
            "name": "tipo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fechaInicio",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "fechaFin",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "venueId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "estado",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "titulo",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Eventos/reservas": {
      "post": {
        "tags": [
          "Eventos"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CrearReservaDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CrearReservaDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CrearReservaDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Eventos/reservas/{id}/confirmar": {
      "put": {
        "tags": [
          "Eventos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Eventos/reservas/{id}/cancelar": {
      "put": {
        "tags": [
          "Eventos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Eventos/{id}/reporte": {
      "get": {
        "tags": [
          "Eventos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CrearEventoDto": {
        "required": [
          "capacidadMaxima",
          "descripcion",
          "fechaHoraFin",
          "fechaHoraInicio",
          "precioEntrada",
          "tipoEvento",
          "titulo",
          "venueId"
        ],
        "type": "object",
        "properties": {
          "titulo": {
            "maxLength": 100,
            "minLength": 5,
            "type": "string"
          },
          "descripcion": {
            "maxLength": 500,
            "minLength": 10,
            "type": "string"
          },
          "venueId": {
            "type": "integer",
            "format": "int32"
          },
          "capacidadMaxima": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "fechaHoraInicio": {
            "type": "string",
            "format": "date-time"
          },
          "fechaHoraFin": {
            "type": "string",
            "format": "date-time"
          },
          "precioEntrada": {
            "maximum": 1.7976931348623157E+308,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "tipoEvento": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CrearReservaDto": {
        "required": [
          "cantidad",
          "emailComprador",
          "eventoId",
          "nombreComprador"
        ],
        "type": "object",
        "properties": {
          "eventoId": {
            "type": "string",
            "format": "uuid"
          },
          "cantidad": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "nombreComprador": {
            "minLength": 1,
            "type": "string"
          },
          "emailComprador": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Eventos"
    }
  ]
}